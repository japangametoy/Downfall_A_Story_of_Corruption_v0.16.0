antha:\\c[0]\\<<br>That wasn’t exactly a high bar to clear."]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>But enough about that waste of space. Please, have a seat—I have something important to discuss."]},{"code":122,"indent":1,"parameters":[22,22,0,0,1]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Sure."]},{"code":117,"indent":1,"parameters":[21]},{"code":117,"indent":1,"parameters":[34]},{"code":205,"indent":1,"parameters":[-1,{"list":[{"code":3,"indent":null},{"code":19,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":1,"parameters":[{"code":3,"indent":null}]},{"code":505,"indent":1,"parameters":[{"code":19,"indent":null}]},{"code":117,"indent":1,"parameters":[31]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>Now that I’m in charge, I’m thinking about making some changes around here."]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,3]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>To do that, I need people around me that I trust."]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,2]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>And right now, I trust you more than anyone else."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>So, how would you feel about working with me?"]},{"code":122,"indent":1,"parameters":[22,22,0,0,11]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Work with you? Are you offering me a job?"]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>I am."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>But not just any job—I want you on the board as an executive."]},{"code":122,"indent":1,"parameters":[22,22,0,0,9]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Are you serious?!"]},{"code":122,"indent":1,"parameters":[32,32,0,0,2]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\>\\c[2]Samantha:\\c[0]\\<<br>One hundred percent. I need you here."]},{"code":122,"indent":1,"parameters":[22,22,0,0,21]},{"code":117,"indent":1,"parameters":[15]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\>\\c[3]Jane:\\c[23]\\< Damn! I did not expect that!\\c[0])"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\>\\c[3]Jane:\\c[23]\\< An executive position at a company this big?\\c[0])"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\>\\c[3]Jane:\\c[23]\\< Opportunities like this don’t come around often...\\c[0
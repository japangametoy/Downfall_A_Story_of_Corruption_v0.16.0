"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<"]},{"code":401,"indent":2,"parameters":["We can't have a conversation like this. Go to the other"]},{"code":401,"indent":2,"parameters":["side of the table."]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":4},
{"id":5,"name":"EV005","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":108,"indent":0,"parameters":["========================================================================="]},{"code":408,"indent":0,"parameters":["                           Event: Steven_01"]},{"code":408,"indent":0,"parameters":["========================================================================="]},{"code":111,"indent":0,"parameters":[1,337,0,1,0]},{"code":111,"indent":1,"parameters":[1,339,0,0,0]},{"code":117,"indent":2,"parameters":[40]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Hello..."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>You must be Jane. Ellen just informed me you'd arrived."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Please, have a seat."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Thank you."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>So, Ms. Jane, you're applying for a position here at Hotel Roseview?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>That’s correct."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>I’ve reviewed your resume, and I must say—it’s impressive!"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>So I’m curious about why you want to work here? Did you see the job description?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>I did. You’re hiring for maid positions, right?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Yes, and you are way overqualified for that. With your background, you could easily secure something better elsewhere."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["(\\>\\c[3]Jane:\\c[23]\\< I can’t tell him I’ve been blacklisted. But I expected this question, so I’ve prepared an answer.\\c[0])"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Well, I used to work in a high-pressure corporate environment. After a few months, I realized it wasn’t for me."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>I’m looking for a fresh start in a calmer, more hands-on role."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>I see. That’s a unique perspective."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>But, working as a maid isn’t as easy as some might think—it comes with its own set of challenges."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Are you sure you’re ready for this, considering your background in desk jobs?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Actually, I do have some experience working as a maid for a family."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Oh, really?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Yes. It’s not the same as working in a large hotel like this, but I’m confident I can handle the responsibilities. I just need the chance to prove myself."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>I like your attitude. A positive mindset is exactly what we need here. "]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Let’s start with a short trial period—this way, we can both see if it’s a good fit. Does that sound fair?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Absolutely! Thank you for the opportunity."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Great. You can start tomorrow. Before you leave, I’d like you to meet some of the team."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Of course. Who should I talk to?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>First, there’s Gary, our Masterchef—you’ll find him in the kitchen."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Then, meet Carrol, our senior maid. She’s experienced and can share useful tips about the role."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Sounds good."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>You’ve probably already met Ellen, our receptionist, and Brian, the hotel boy."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>Reintroduce yourself to them, but this time as a new team member."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>Got it. Anything else?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>That should cover it. Just meet me tomorrow morning before you start."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[3]Jane:\\c[0]\\<<br>I will. Again, thanks for the opportunity. I’ll do my best."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\>\\c[2]Mr. Steven:\\c[0]\\<<br>I’m sure you will."]},{"code":117,"indent":2,"parameters":[40]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":0,"y":0}

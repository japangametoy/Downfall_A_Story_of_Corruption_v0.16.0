rameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>Yes. His name is Johnson and he is a cop."]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Well, I don’t usually don’t talk about my clients, but since Madame asked me to cooperate with you, I guess I could answer a few questions."]},{"code":122,"indent":1,"parameters":[22,22,0,0,1]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>Thanks for your help."]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Sure. Just make sure I don’t get in any trouble for that."]},{"code":122,"indent":1,"parameters":[22,22,0,0,1]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>You won’t. I promise."]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,2]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Alright then, what do you know?"]},{"code":122,"indent":1,"parameters":[22,22,0,0,1]},{"code":117,"indent":1,"parameters":[16]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>I heard that you are his favorite?"]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>I guess you can say that."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>He usually asks for me every time he comes here."]},{"code":122,"indent":1,"parameters":[22,22,0,0,3]},{"code":117,"indent":1,"parameters":[16]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>Do you know why he took such a liking to you?"]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,3]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Well, he once said that I remind him of his ex-girlfriend or something."]},{"code":122,"indent":1,"parameters":[22,22,0,0,3]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>Make sense. She was probably his first love, so has a special place in his heart."]},{"code":122,"indent":1,"parameters":[22,22,0,0,1]},{"code":117,"indent":1,"parameters":[16]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>Does he ever talk to you about anything else?"]},{"code":122,"indent":1,"parameters":[32,32,0,0,7]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>I don’t know what exactly you want to know."]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,3]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>He becomes chatterbox after we done fucking, But he mostly talk about mundane things."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Like how he hates his captain, what he ate for lunch, things like that."]},{"code":122,"indent":1,"parameters":[32,32,0,0,1]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>But mostly he complains about his work."]},{"code":122,"indent":1,"parameters":[22,22,0,0,3]},{"code":117,"indent":1,"parameters":[14]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[3]Jane:\\c[0]<br>I take it things are not going well for him there?"]},{"code":122,"indent":1,"parameters":[32,32,0,0,3]},{"code":122,"indent":1,"parameters":[36,36,0,0,4]},{"code":117,"indent":1,"parameters":[24]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>Yeah. Apparently there’s an internal investigation going on against him."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>He is very worried about it."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\\c[2]Maria:\\c[0]<br>He said he might even get fired."]},{"code":122,"indent":1,"parameters":[22,22,0,0,21]},{"code":117,"indent":1,"parameters":[15]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\c[3]Jane:\\c[23] Now it makes sense. This is why he is asking for more money.\\c[0])"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\c[3]Jane:\\c[23] He wants to make as much money as possible before his time is up.\\c[0])"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["(\\c[3]Jane:\\c[23] That's very useful info. Let’s see if I can find out an
:["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[3]Jane:\\c[0]<br>Look, I am sorry. I had no idea I would find you here."]},{"code":122,"indent":2,"parameters":[32,32,0,0,5]},{"code":122,"indent":2,"parameters":[36,36,0,0,4]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>But then..."]},{"code":122,"indent":2,"parameters":[32,32,0,0,6]},{"code":122,"indent":2,"parameters":[36,36,0,0,2]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>No! No way I am fucking you! Doesn't matter how much money you offer."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>You can choose any other girl you like. Just leave me alone."]},{"code":122,"indent":2,"parameters":[22,22,0,0,3]},{"code":117,"indent":2,"parameters":[14]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[3]Jane:\\c[0]<br>You got the wrong idea. I am not here to fuck anyone."]},{"code":122,"indent":2,"parameters":[32,32,0,0,5]},{"code":122,"indent":2,"parameters":[36,36,0,0,2]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>Then why are you here? Don't tell me..."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>You...you also work here?"]},{"code":122,"indent":2,"parameters":[32,32,0,0,2]},{"code":122,"indent":2,"parameters":[36,36,0,0,1]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>Serves you right! For what you did to me."]},{"code":122,"indent":2,"parameters":[22,22,0,0,4]},{"code":117,"indent":2,"parameters":[15]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[3]Jane:\\c[0]<br>I can't apologize enough for what happened to you. It was never my intention."]},{"code":122,"indent":2,"parameters":[32,32,0,0,5]},{"code":122,"indent":2,"parameters":[36,36,0,0,1]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>You empty apology means nothing to me. You destroyed my life."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>I had a decent job, and now look at me!"]},{"code":122,"indent":2,"parameters":[32,32,0,0,4]},{"code":122,"indent":2,"parameters":[36,36,0,0,4]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>I am selling my body to make ends meet."]},{"code":122,"indent":2,"parameters":[22,22,0,0,7]},{"code":117,"indent":2,"parameters":[14]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[3]Jane:\\c[0]<br> Couldn't you get another job in some other company?"]},{"code":122,"indent":2,"parameters":[32,32,0,0,3]},{"code":122,"indent":2,"parameters":[36,36,0,0,4]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>No I can’t. Because he didn't even give me a letter of recommendation."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>No one else will hire someone who just got fired from one of the biggest companies in this city."]},{"code":122,"indent":2,"parameters":[22,22,0,0,3]},{"code":117,"indent":2,"parameters":[14]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[3]Jane:\\c[0]<br>But isn't it a bit extreme to work as a prostitute?"]},{"code":122,"indent":2,"parameters":[32,32,0,0,4]},{"code":122,"indent":2,"parameters":[36,36,0,0,3]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>I had no other choice, alright?"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>I have sick parents to take care of. I need to pay their medical bill and other expenses."]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>So I needed some money very quickly."]},{"code":122,"indent":2,"parameters":[32,32,0,0,5]},{"code":122,"indent":2,"parameters":[36,36,0,0,2]},{"code":117,"indent":2,"parameters":[24]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>But why am I even explaining it to you!"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>You are the last person to have any right to judge me!"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\\c[2]Sarah:\\c[0]<br>Especially since you also work here."]},{"code":122,"indent":2,"parameters":[22,22,0,0,21]},{"code":117,"indent":2,"parameters":[15]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["(\\c[3]Jane:\\c[23] She is right.\\c[0])"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["(\\c[3]Jane:\\c[23] Because of me, she lost her job and ended up here.\\c[0])"]},{"code":122,"indent":2,"parameters":[22,22,0,0,15]},{"code":117,"indent":2,"parameters":[15]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["(\\c[3]Jane:\\c[23] She has every right to hate me.\\c[0])"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["(\\c[3]Jane:\\c[23] I swear I will find a way to make it right. I w